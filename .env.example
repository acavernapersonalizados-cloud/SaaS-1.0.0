# ─────────────────────────────────────────────────────────────────────────────
# PrecificaAteliê — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copie este arquivo para .env
# 2. Preencha com as credenciais do seu projeto Firebase
#    Firebase Console → Configurações do Projeto → Seus apps → Config do SDK
# 3. Reinicie o servidor de desenvolvimento após alterar

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=        # opcional

# Gemini AI
# Obtenha em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
