rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Public product images (catalog — no auth required) ────────────────
    // Read is public so the PublicCatalog page can show product images
    // without requiring users to be logged in.
    match /stores/{storeId}/products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Store logos and branding assets ───────────────────────────────────
    match /stores/{storeId}/branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Everything else requires authentication ────────────────────────────
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
